{
  "name": "@thisismissem/adonisjs-atproto-tap",
  "description": "Adonis.js provider for AT Protocol Tap Client",
  "version": "3.1.2",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.26.1+sha512.664074abc367d2c9324fdc18037097ce0a8f126034160f709928e9e9f95d98714347044e5c3164d65bd5da6c59c6be362b107546292a8eecb7999196e5ce58fa",
  "type": "module",
  "files": [
    "build",
    "!build/bin",
    "!build/tests"
  ],
  "main": "build/index.js",
  "exports": {
    ".": "./build/index.js",
    "./provider": "./build/providers/tap_provider.js",
    "./services/tap": "./build/services/tap.js",
    "./types": "./build/src/types.js"
  },
  "scripts": {
    "changeset": "changeset",
    "copy:templates": "copyfiles \"stubs/**/*.stub\" build",
    "typecheck": "tsc --noEmit",
    "lint": "pnpm run typecheck && eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:write": "prettier --write",
    "quick:test": "node --import=@poppinss/ts-exec --enable-source-maps bin/test.ts",
    "pretest": "pnpm run lint",
    "test": "c8 pnpm run quick:test",
    "types:check": "attw --pack . --profile esm-only --profile node16 --ignore-rules=cjs-resolves-to-esm",
    "precompile": "npm run lint",
    "compile": "tsdown && tsc --emitDeclarationOnly --declaration",
    "postcompile": "npm run copy:templates",
    "build": "pnpm run compile",
    "version-packages": "changeset version && pnpm run format:write CHANGELOG.md && git add package.json CHANGELOG.md",
    "release": "pnpm run build && changeset publish",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "adonisjs",
    "adonis",
    "atproto",
    "at protocol",
    "tap"
  ],
  "author": "Emelia Smith",
  "license": "MIT",
  "contributors": [
    {
      "name": "Emelia Smith",
      "url": "https://github.com/thisismissem"
    }
  ],
  "repository": {
    "url": "https://github.com/ThisIsMissEm/adonisjs-atproto-tap"
  },
  "dependencies": {
    "@poppinss/utils": "^7.0.1"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.0.0",
    "@adonisjs/core": "^7.0.1",
    "@adonisjs/eslint-config": "3.0.0",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "^2.0.0",
    "@arethetypeswrong/cli": "^0.18.2",
    "@atproto/tap": "^0.2.8",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@japa/assert": "^4.2.0",
    "@japa/runner": "^5.3.0",
    "@poppinss/ts-exec": "^1.4.4",
    "@types/node": "^25.3.5",
    "c8": "^11.0.0",
    "copyfiles": "^2.4.1",
    "eslint": "^10.0.3",
    "np": "^11.0.2",
    "prettier": "^3.8.1",
    "tsdown": "^0.22.12",
    "typescript": "^5.4.5",
    "yalc": "1.0.0-pre.53"
  },
  "peerDependencies": {
    "@adonisjs/assembler": "^8.0.0",
    "@adonisjs/core": "^7.0.1",
    "@atproto/tap": "^0.2.8"
  },
  "peerDependenciesMeta": {
    "@adonisjs/assembler": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "tsdown": {
    "entry": [
      "./index.ts",
      "./configure.ts",
      "./providers/tap_provider.ts",
      "./services/tap.ts",
      "./src/types.ts"
    ],
    "outDir": "./build",
    "clean": true,
    "format": "esm",
    "minify": "dce-only",
    "fixedExtension": false,
    "dts": false,
    "treeshake": false,
    "sourcemaps": false,
    "target": "esnext",
    "unbundle": true
  },
  "c8": {
    "reporter": [
      "text",
      "html"
    ],
    "exclude": [
      "tests/**"
    ]
  },
  "prettier": "@adonisjs/prettier-config"
}
